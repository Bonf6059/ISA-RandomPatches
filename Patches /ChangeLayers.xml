<?xml version="1.0" encoding="utf-8"?>

<Patch>

<!-- Change layer of Heavy bandolier -->

  <Operation Class="PatchOperationFindMod">
  <mods>
    <li>DV</li>
  </mods>
  <match Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="HeavyBandolier"]/apparel/layers</xpath>
			<value>
				<layers>
					<li>ISA_ShellAttachment</li>
				</layers>
			</value>
  </match>
  <nomatch Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="HeavyBandolier"]/apparel/layers</xpath>
			<value>
				<layers>
					<li>ISA_ShellAttachment</li>
				</layers>
			</value>
  </nomatch>
</Operation>

</Patch>
